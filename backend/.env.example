# ─── Trading Journal — Environment Configuration ─────────────────────
# Copy this file to ".env" in the same folder and edit to match YOUR setup.
# Re-start the backend after changing anything in here.

# ─── Sierra Chart installations ────────────────────────────────────
# Comma-separated list. The importer scans the "TradeActivityLogs/" subfolder
# of each path; the tick-data reader scans the "Data/" subfolder of each path.
# Most users only have ONE Sierra Chart install — that's fine, just one path.
SIERRA_CHART_PATHS=C:/SierraChart,C:/SierraChartApex

# ─── Quantower (optional) ──────────────────────────────────────────
# Quantower trade history is read from local SQLite "user-trades.db" files.
# Each Quantower install has its own — comma-separated again.
# Leave empty if you don't use Quantower.
QUANTOWER_ROOTS=C:/Quantower,C:/QuantowerBy

# ─── Optional Parquet tick-data cache ──────────────────────────────
# If you converted Sierra .scid files into parquet (e.g. via TickerManagement),
# point this at the root folder. The journal will use parquet when available
# (faster) and fall back to .scid when not. Leave blank if you don't have one.
TICKER_LIBRARY=

# ─── Database ──────────────────────────────────────────────────────
# Absolute path or relative to backend/. Defaults to backend/journal.db.
DB_PATH=

# ─── Backend server ────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# ─── Frontend CORS origins (comma-separated) ──────────────────────
# Add the URL(s) your browser uses to reach the frontend.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Logging (optional) ───────────────────────────────────────────
# Levels: DEBUG / INFO / WARNING / ERROR.  Default INFO.
# Logs land in  backend/logs/journal-YYYY-MM-DD.log  (one file per UTC day)
# and are also echoed to the backend console window.
# Hit /api/diagnostics to see the recent tail without opening the files.
LOG_LEVEL=INFO

# Override log location (default: backend/logs/)
LOG_DIR=

# ─── Python launcher (optional but RECOMMENDED on Windows) ────────
# Windows ships a `python.exe` stub in WindowsApps/ that won't have your pip
# packages — start.bat will pick that up by mistake and the backend will fail
# with "ModuleNotFoundError: No module named 'fastapi'".
# Set this to the absolute path of the Python you installed pip deps into.
# Examples:
#   PYTHON=C:/Python311/python.exe
#   PYTHON=E:/Anaconda/python.exe
#   PYTHON=%LOCALAPPDATA%/Programs/Python/Python311/python.exe
# Leave blank to let start.bat probe `py` then `python` on PATH.
PYTHON=
